FRONTEND_HOST=your_frontend_host
BACKEND_USER_URL=your_backend_host
USERS_DB_URL=your_user_db_url

BACKEND_CORS_ORIGINS=your_cors_origins (example: "http://127.0.0.1:8001,http://127.0.0.1:8002,http://127.0.0.1:8003")


CLIENT_ID=your_gcc_client_id
CLIENT_SECRET_KEY=your_gcc_client_secret

SECRET_KEY=your_secret_key
ALGORITHM=your_algorithm
ACCESS_TOKEN_EXPIRE_DAYS=1